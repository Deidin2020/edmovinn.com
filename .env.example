# Backend API (safe to expose — listed in the `env` allowlist in nuxt.config.js)
API_URL=https://app.edmov.com
API_BASE_URL=https://app.edmov.com/api/

# --- Secrets: server-side only ------------------------------------------------
# Never add these to the `env` block in nuxt.config.js — anything listed there is
# compiled into the public browser bundle.

# Set to `test` to run against the bank sandbox with the KUVEYT_TEST_* values
# below. Any other value (including unset) charges the live merchant account.
KUVEYT_ENV=test

# Live merchant account
KUVEYT_CUSTOMER_ID=
KUVEYT_MERCHANT_ID=
KUVEYT_USERNAME=
KUVEYT_PASSWORD=

# Sandbox account — request these from Kuveyt Turk, do not guess them.
KUVEYT_TEST_CUSTOMER_ID=
KUVEYT_TEST_MERCHANT_ID=
KUVEYT_TEST_USERNAME=
KUVEYT_TEST_PASSWORD=
KUVEYT_TEST_PAY_URL=
KUVEYT_TEST_PROVISION_URL=

KUVEYT_OK_URL=https://YOUR_DOMAIN.com/api/kuveyt/ok
KUVEYT_FAIL_URL=https://YOUR_DOMAIN.com/api/kuveyt/fail

# Production gateway
KUVEYT_PAY_URL=https://sanalpos.kuveytturk.com.tr/ServiceGateWay/Home/ThreeDModelPayGate
KUVEYT_PROVISION_URL=https://sanalpos.kuveytturk.com.tr/ServiceGateWay/Home/ThreeDModelProvisionGate

# Shared secret for the server-to-server settle call to the booking API.
# While this is empty the middleware skips the call and the backend can only rely
# on the return-URL query string, which the customer can tamper with.
KUVEYT_INTERNAL_SECRET=
# Defaults to {API_URL}/api/internal/payments/kuveyt-turk/settle
KUVEYT_SETTLE_URL=

# Abuse protection on /api/kuveyt/start (optional — defaults shown)
KUVEYT_RATE_LIMIT_MAX=5
KUVEYT_RATE_LIMIT_WINDOW_MS=600000
